model User {
  id             String          @id @default(uuid())
  email          String          @unique
  name           String?
  password       String
  role           Role            @default(USER)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  
  // Relations
  properties     Property[]
  rentalRequests RentalRequest[]
  payments       Payment[]
  reviews        Review[]
}